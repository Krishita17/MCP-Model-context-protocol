# MCP Security Suite — Environment Configuration
# Copy this file to .env and fill in the keys you have.
# Only Ollama is required (local, no key needed). All others are optional.

# ─── Ollama (local, free) ───────────────────────────────────────────────────
# Install: https://ollama.com  then: ollama pull qwen2.5
OLLAMA_MODEL=qwen2.5
OLLAMA_HOST=http://localhost:11434

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Anthropic ──────────────────────────────────────────────────────────────
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Google Gemini ──────────────────────────────────────────────────────────
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ─── OpenRouter (multi-model gateway) ──────────────────────────────────────
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ─── Default provider ──────────────────────────────────────────────────────
# Which provider to use when --provider is not specified
MCP_DEFAULT_PROVIDER=ollama
