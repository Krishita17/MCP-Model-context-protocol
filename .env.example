# MCP Security Suite — Environment Configuration
# Copy this file to .env and fill in the keys you have.
# Only Ollama is required (local, no key needed). All others are optional.
# Missing keys are gracefully skipped — the matrix runs with what's available.

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
# Used for: gpt-4o, gpt-4o-mini backends
OPENAI_API_KEY=

# ─── Anthropic ──────────────────────────────────────────────────────────────
# Get key: https://console.anthropic.com/settings/keys
# Used for: claude-sonnet backend
ANTHROPIC_API_KEY=

# ─── Google Gemini ──────────────────────────────────────────────────────────
# Get key: https://aistudio.google.com/app/apikey
# Used for: gemini-2.5 backend (maps to gemini-2.0-flash)
GOOGLE_API_KEY=

# ─── Ollama (local, free) ───────────────────────────────────────────────────
# Install: https://ollama.com  then: ollama pull llama3.1:8b
# Used for: llama-3.1-8b, llama-3.1-70b backends (no API key needed)
OLLAMA_HOST=http://localhost:11434

# ─── OpenRouter (multi-model gateway, used by src/providers/) ─────────────
OPENROUTER_API_KEY=

# ─── Default provider ──────────────────────────────────────────────────────
MCP_DEFAULT_PROVIDER=ollama
